{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "submorph",
	"main": "./src/worker/index.ts",
	"compatibility_date": "2026-07-13",
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"kv_namespaces": [
		{
			"binding": "SUBMORPH_STORE",
			"id": "ab1252af3b494ab88d8b3b941863cf73"
		}
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "submorph-db",
			"database_id": "221bf55c-9836-4a7f-9884-e996828a318f"
		}
	],
	"ratelimits": [
		{
			"name": "RATE_LIMITER",
			"namespace_id": "92201",
			"simple": {
				"limit": 30,
				"period": 60
			}
		},
		{
			"name": "LOGIN_RATE_LIMITER",
			"namespace_id": "92202",
			"simple": {
				"limit": 5,
				"period": 60
			}
		}
	],
	"routes": [
		{
			"pattern": "submorph.xqd.pp.ua",
			"custom_domain": true
		}
	],
	"assets": {
		"directory": "./dist/client",
		"not_found_handling": "single-page-application"
	}
}
